{% extends 'base.html.twig' %}

{% block title %}Character index{% endblock %}

{% block body %}
    <h1>Character index</h1>
    <form method="get">
        <input type="text" name="search" placeholder="Search for a character..." value="{{ app.request.get('search') }}">
        <button type="submit" class="btn btn-primary">Search</button>
    </form>

    <h3>Classes filter</h3>
    <form method="get">
        <select name="class">
            <option value="">All classes</option>
            {% for class in classes %}
                <option value="{{ class.id }}" {% if app.request.get('class') == class.id %}selected{% endif %}>
                    {{ class.name }}
                </option>
            {% endfor %}
        </select>

        <button type="submit">Filter</button>
    </form>

    <h3>Races filter</h3>
    <form method="get">
        <select name="race">
            <option value="">All races</option>
            {% for race in races %}
                <option value="{{ race.id }}" {% if app.request.get('race') == race.id %}selected{% endif %}>
                    {{ race.name }}
                </option>
            {% endfor %}
        </select>

        <button type="submit">Filter</button>
    </form>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Level</th>
                <th>Strength</th>
                <th>Dexterity</th>
                <th>Constitution</th>
                <th>Intelligence</th>
                <th>Wisdom</th>
                <th>Charisma</th>
                <th>HealthPoints</th>
                <th>Race</th>
                <th>Avatar</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>

        {% for character in characters %}
            <tr>
                <td>{{ character.id }}</td>
                <td>{{ character.name }}</td>
                <td>{{ character.level }}</td>
                <td>{{ character.strength }}</td>
                <td>{{ character.dexterity }}</td>
                <td>{{ character.constitution }}</td>
                <td>{{ character.intelligence }}</td>
                <td>{{ character.wisdom }}</td>
                <td>{{ character.charisma }}</td>
                <td>{{ character.healthPoints }}</td>
                <td>{{ character.race.name }}</td>
                <td>
                    {% if character.avatarFileName %}
                        <img src="{{ asset('uploads/avatars/' ~ character.avatarFileName) }}" alt="{{ character.name }}" width="75">
                    {% else %}
                        <span>No avatar</span>
                    {% endif %}</td>
                <td>
                    <a href="{{ path('app_character_show', {'id': character.id}) }}">show</a>
                    <a href="{{ path('app_character_edit', {'id': character.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="11">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_character_new') }}">Create new</a>
{% endblock %}
