{% extends 'base.html.twig' %}

{% block title %}Party{% endblock %}

{% block body %}
    <h1>Party</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ party.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ party.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ party.description }}</td>
            </tr>
            <tr>
                <th>MaxSize</th>
                <td>{{ party.maxSize }}</td>
            </tr>
        <tr>
            <th>Place</th>
            <td>{{ size }}</td>
        </tr>
        </tbody>
    </table>


    {{ include('party/_subscribe_form.html.twig') }}
    <a href="{{ path('app_party_index') }}">back to list</a>



    {{ include('party/_delete_form.html.twig') }}
{% endblock %}
